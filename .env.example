# Application
APP_NAME=MyAIOps
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9900

# ==================== DeepSeek LLM (默认主 provider) ====================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_ROUTER_MODEL=deepseek-v4-flash

# ==================== DashScope LLM (备选, 模型名以 qwen 开头时触发) ====================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-max
DASHSCOPE_ROUTER_MODEL=qwen-turbo

# ==================== 本地 Embedding (BGE) ====================
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh
LOCAL_EMBEDDING_DIM=512
LOCAL_EMBEDDING_DEVICE=cpu

# ==================== 本地 Reranker (BGE CrossEncoder) ====================
RAG_RERANK_MODEL=BAAI/bge-reranker-base

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=multi_agent_kb
MILVUS_TIMEOUT_MS=10000

# RAG
RAG_TOP_K=3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
KB_ADMIN_TOKEN=change-this-admin-token
RAG_HYBRID_ENABLED=true
RAG_RERANK_ENABLED=true

# Redis session memory
REDIS_URL=redis://localhost:6379/0
RAG_CHAT_MEMORY_ENABLED=false
RAG_CHAT_HISTORY_TURNS=3
RAG_CHAT_MEMORY_TTL_SEC=604800

# MCP endpoints
MCP_SYSTEM_URL=http://localhost:8005/mcp
MCP_WEBSEARCH_URL=http://localhost:8006/mcp
MCP_WINLOG_URL=http://localhost:8008/mcp
MCP_NETWORK_URL=http://localhost:8009/mcp
MCP_DOCKER_URL=http://localhost:8011/mcp

# Agent runtime
AGENT_MAX_STEPS=5
AGENT_MAX_CONCURRENCY=2
RAG_MAX_CONCURRENCY=5
PERMISSION_MODE=normal
GUARDRAILS_BLOCK_HIGH_RISK_TOOLS=true
EXECUTOR_PARALLEL_ENABLED=true
EXECUTOR_MAX_ITERS=4
EXECUTOR_MAX_PARALLEL=6

# Web search: mock / tavily / ddgs
WEB_SEARCH_PROVIDER=mock
TAVILY_API_KEY=

# Local LLM fallback
LOCAL_LLM_ENABLED=false
LOCAL_LLM_FORCE=false
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_PROBE_HOST=api.deepseek.com

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=14
